{
  "name": "one.fotos",
  "version": "0.1.0",
  "description": "Git-based photo collection manager with self-contained HTML viewer",
  "type": "module",
  "bin": {
    "fotos": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@refinio/chat.media": "workspace:*",
    "@refinio/fotos.core": "workspace:*",
    "@refinio/one.core": "workspace:*",
    "@refinio/sync.core": "workspace:*",
    "@refinio/trie.core": "workspace:*",
    "commander": "^12.0.0",
    "exifreader": "^4.14.0",
    "onnxruntime-node": "^1.22.0",
    "sharp": "^0.33.0"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "vitest": "^3.0.0"
  }
}
